# Copy to .env (gitignored). All are read as plain environment variables.

# Postgres connection string for the mlsgrid-sync database this server reads.
# In production, use a read-only role (see docs/adapters.md).
MLSGRID_MCP_DATABASE_URL=postgres://user:pass@localhost:5432/mls?sslmode=disable

# Optional: override the schema holding the mlsgrid-sync tables (default: mlsgrid).
# MLSGRID_MCP_DATABASE_SCHEMA=mlsgrid
